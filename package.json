{
  "name": "github-digest-agent",
  "version": "2.0.0",
  "description": "AI-powered GitHub digest agent with web dashboard — scans repos, generates Claude-powered summaries, emails digests, and serves a real-time dashboard.",
  "type": "module",
  "scripts": {
    "start": "node src/scheduler.js",
    "dev": "node src/scheduler.js --now",
    "scan": "node src/index.js",
    "server": "node src/server.js",
    "dashboard": "node src/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.7",
    "express": "^4.22.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.0",
    "octokit": "^4.1.2"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.4"
  }
}
