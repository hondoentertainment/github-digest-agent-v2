{
  "name": "github-digest-agent",
  "version": "3.2.0",
  "description": "AI-powered GitHub digest agent with web dashboard — scans repos, generates Claude-powered summaries, emails digests, and serves a real-time dashboard.",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "start": "node src/scheduler.js",
    "dev": "node src/scheduler.js --now",
    "scan": "node src/index.js",
    "server": "node src/server.js",
    "dashboard": "node src/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.5",
    "octokit": "^4.1.2",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "supertest": "^7.2.2",
    "vitest": "^4.1.4"
  }
}
