# GitHub Personal Access Token (requires: repo, read:org, security_events scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI configuration
# Provider: claude | openai | gemini (default: claude)
AI_PROVIDER=claude
AI_MODEL=claude-sonnet-4-20250514

# API keys (set the one matching your AI_PROVIDER)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=
GEMINI_API_KEY=

# Email configuration (Gmail example — use app password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_TO=you@gmail.com
EMAIL_FROM=GitHub Digest <you@gmail.com>

# Dashboard server port
PORT=3000

# Schedule (cron format — default: 7:00 AM daily)
CRON_SCHEDULE=0 7 * * *

# Optional: comma-separated repos to exclude
EXCLUDE_REPOS=

# Dashboard authentication (leave blank to disable)
DASHBOARD_PASSWORD=
# JWT signing secret (recommended in production; falls back to DASHBOARD_PASSWORD when unset)
JWT_SECRET=
JWT_EXPIRES_IN=24h

# API write rate limit (mutating requests per IP per minute)
API_WRITE_RATE_LIMIT=120

# Trend API: max days queryable and in-memory cache TTL (ms)
MAX_TREND_DAYS=365
TREND_CACHE_TTL_MS=60000

# WebSocket /ws/scan: max wait (ms) for first auth message when dashboard auth is enabled
WS_AUTH_TIMEOUT_MS=15000

# PagerDuty Events API v2 (optional — alert rules can trigger a page when set)
PAGERDUTY_ROUTING_KEY=

# Linear (optional — POST /api/integrations/ticket)
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# Jira Cloud (optional)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# Anomaly spike thresholds: set in dashboard Settings → Alert rules (total-items multiplier & lookback), not env-only.

# Scanners to enable (comma-separated, default: all)
# Options: builds, prs, security, tokens, issues, branches
ENABLED_SCANNERS=

# Scan rules
STALE_BRANCH_DAYS=30
BUILD_WINDOW_HOURS=24
SEVERITY_THRESHOLD=low
MAX_ITEMS_PER_SCANNER=100

# Maximum scan history entries to keep
MAX_SCAN_HISTORY=50

# Override persisted data directory (default: ./data locally; on Vercel use /tmp/... or leave unset for auto /tmp path)
# DATA_DIR=

# Slack webhook URL (leave blank to disable)
SLACK_WEBHOOK_URL=

# Discord webhook URL (leave blank to disable)
DISCORD_WEBHOOK_URL=

# GitHub webhook secret (for webhook-triggered scans)
WEBHOOK_SECRET=
