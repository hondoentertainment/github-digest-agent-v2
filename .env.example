# GitHub Personal Access Token (requires: repo, read:org, security_events scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key for Claude-powered summaries
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI model (default: claude-sonnet-4-20250514)
AI_MODEL=claude-sonnet-4-20250514

# Email configuration (Gmail example — use app password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_TO=you@gmail.com
EMAIL_FROM=GitHub Digest <you@gmail.com>

# Dashboard server port
PORT=3000

# Schedule (cron format — default: 7:00 AM daily)
CRON_SCHEDULE=0 7 * * *

# Optional: comma-separated repos to exclude
EXCLUDE_REPOS=

# Dashboard authentication (leave blank to disable)
DASHBOARD_PASSWORD=

# Scanners to enable (comma-separated, default: all)
# Options: builds, prs, security, tokens, issues, branches
ENABLED_SCANNERS=

# Scan rules
STALE_BRANCH_DAYS=30
BUILD_WINDOW_HOURS=24
SEVERITY_THRESHOLD=low
MAX_ITEMS_PER_SCANNER=100

# Maximum scan history entries to keep
MAX_SCAN_HISTORY=50

# Slack webhook URL (leave blank to disable)
SLACK_WEBHOOK_URL=

# Discord webhook URL (leave blank to disable)
DISCORD_WEBHOOK_URL=
